arr = list(map(int, input().split()))
n = len(arr)
i = 0
j = n // 2
while i < j and j < n:
    if arr[i] <= arr[j]:
        i += 1
    else:
        val = arr[j]
        idx = j
        while idx > i:
            arr[idx] = arr[idx - 1]
            idx -= 1
        arr[i] = val
        i += 1
        j += 1
print(arr)
